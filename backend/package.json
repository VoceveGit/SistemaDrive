{
  "name": "spreadsheet-sync-backend",
  "version": "1.0.0",
  "description": "API SpreadsheetSync — ingestão de planilhas do Google Drive",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "prisma db push && node dist/src/index.js",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:ensure": "node scripts/ensure-db.mjs",
    "dev:setup": "node scripts/ensure-db.mjs && prisma db push",
    "db:studio": "prisma studio"
  },
